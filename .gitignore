#include <stdio.h>
#include <stdlib.h> // For rand() and srand()
#include <string.h> // For strlen(), strcmp(), strchr()
#include <ctype.h>  // For toupper(), isalpha()
#include <time.h>   // For time()

// --- Constants ---
#define MAX_GUESSES 6
#define MAX_WORD_LENGTH 50
#define MAX_GUESSED_LETTERS 27 // 26 letters + 1 null terminator

// --- Function Prototypes ---
void printHangman(int wrongGuesses);
void clearScreen();

// --- Main Game Logic ---
int main() {
    // List of words to choose from
    const char *wordList[] = {
        "COMPUTER", "PROGRAMMING", "LANGUAGE", "GITHUB",
        "DEVELOPER", "ALGORITHM", "KEYBOARD", "PYTHON",
        "JAVASCRIPT", "HANGMAN", "TERMINAL", "LINUX"
    };
    int wordCount = sizeof(wordList) / sizeof(wordList[0]);

    // Seed the random number generator
    srand(time(NULL));

    // Pick a random word from the list
    const char *secretWord = wordList[rand() % wordCount];
    int wordLength = strlen(secretWord);

    // --- Game State Variables ---
    char progress[MAX_WORD_LENGTH];       // The player's current guessed word (e.g., "H_NGM_N")
    char guessedLetters[MAX_GUESSED_LETTERS] = ""; // A string of all letters guessed
    int wrongGuesses = 0;
    int guessedCount = 0;

    // Initialize the progress string with underscores
    for (int i = 0; i < wordLength; i++) {
        progress[i] = '_';
    }
    progress[wordLength] = '\0'; // Null-terminate the string

    clearScreen();
    printf("--- Welcome to Hangman! ---\n");
    printf("Try to guess the %d-letter word.\n", wordLength);

    // --- Main Game Loop ---
    while (wrongGuesses < MAX_GUESSES) {
        // Print the current game state
        printf("\n--------------------------------\n");
        printHangman(wrongGuesses);
        printf("\n");
        printf("Word:    %s\n", progress);
        printf("Guessed: %s\n", guessedLetters);
        printf("You have %d wrong guesses left.\n", MAX_GUESSES - wrongGuesses);
        printf("\n");

        // Get player's guess
        char guess;
        printf("Enter your guess: ");
        
        // The " %c" format specifier is important!
        // The space skips any leading whitespace (like the 'Enter' key press)
        scanf(" %c", &guess);
        guess = toupper(guess); // Standardize to uppercase

        // --- Input Validation ---
        // Check if it's a letter
        if (!isalpha(guess)) {
            printf("'%c' is not a valid letter. Try again.\n", guess);
            continue;
        }
        
        // Check if it's already been guessed
        if (strchr(guessedLetters, guess) != NULL) {
            printf("You already guessed '%c'. Try again.\n", guess);
            continue;
        }

        // Add the guess to the list of guessed letters
        guessedLetters[guessedCount++] = guess;
        guessedLetters[guessedCount] = '\0'; // Keep it a valid string

        // --- Check the Guess ---
        int found = 0;
        for (int i = 0; i < wordLength; i++) {
            if (secretWord[i] == guess) {
                progress[i] = guess;
                found = 1;
            }
        }

        // Update game state based on the guess
        if (found) {
            printf("\nGood guess! '%c' is in the word.\n", guess);
        } else {
            printf("\nSorry, '%c' is not in the word.\n", guess);
            wrongGuesses++;
        }

        // --- Check for Win Condition ---
        // If the progress string is identical to the secret word
        if (strcmp(progress, secretWord) == 0) {
            printf("\n================================\n");
            printf("🎉 YOU WIN! Congratulations! 🎉\n");
            printf("The word was: %s\n", secretWord);
            printf("================================\n");
            return 0; // End the game
        }
    }

    // --- End of Game (Loss) ---
    // If the loop finishes, the player has lost
    printf("\n================================\n");
    printf("GAME OVER! You lost. 😥\n");
    printHangman(wrongGuesses);
    printf("The word was: %s\n", secretWord);
    printf("================================\n");

    return 0;
}

/**
 * @brief Prints the ASCII art for the hangman based on the number of wrong guesses.
 * @param wrongGuesses The number of incorrect guesses made so far.
 */
void printHangman(int wrongGuesses) {
    printf(" +---+\n");
    printf(" |   |\n");
    printf(" |   %c\n", (wrongGuesses > 0) ? 'O' : ' ');
    printf(" |  %c%c%c\n", (wrongGuesses > 2) ? '/' : ' ', (wrongGuesses > 1) ? '|' : ' ', (wrongGuesses > 3) ? '\\' : ' ');
    printf(" |  %c %c\n", (wrongGuesses > 4) ? '/' : ' ', (wrongGuesses > 5) ? '\\' : ' ');
    printf(" |\n");
    printf("=========\n");
}

/**
 * @brief A simple way to clear the console screen for a cleaner look.
 * This is not standard, but works on most (Linux/macOS) systems.
 * On Windows, you might use "cls" instead.
 */
void clearScreen() {
    // A simple (though not perfect) way to "clear" the screen
    // by printing many newlines.
    // A system-specific command like system("clear") or system("cls")
    // is an alternative but is generally bad practice.
    for (int i = 0; i < 30; i++) {
        printf("\n");
    }
}
